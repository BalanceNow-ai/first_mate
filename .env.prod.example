# ============================================================
# Helm Marine — Production Environment Variables
# Copy to .env.prod and fill in real values
# ============================================================

# --- Application ---
APP_ENV=production
SECRET_KEY=          # Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
ALLOWED_ORIGINS=https://yourdomain.co.nz,https://app.yourdomain.co.nz

# --- Database (internal Docker network) ---
POSTGRES_USER=helm
POSTGRES_PASSWORD=   # Generate a strong password
POSTGRES_DB=helm_db
DATABASE_URL=postgresql+asyncpg://helm:YOUR_PG_PASSWORD@db:5432/helm_db

# --- Redis (internal Docker network) ---
REDIS_PASSWORD=      # Generate a strong password
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@redis:6379/0

# --- Supabase Auth ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Laybuy ---
LAYBUY_API_KEY=
LAYBUY_API_SECRET=
LAYBUY_SANDBOX=false

# --- Typesense (internal Docker network) ---
TYPESENSE_HOST=typesense
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=   # Generate a strong key
TYPESENSE_SEARCH_ONLY_KEY=

# --- NZ Post ---
NZPOST_CLIENT_ID=
NZPOST_CLIENT_SECRET=
NZPOST_ACCOUNT_NUMBER=

# --- Aramex NZ ---
ARAMEX_API_KEY=
ARAMEX_ACCOUNT_NUMBER=

# --- Mapbox ---
MAPBOX_ACCESS_TOKEN=

# --- OpenAI ---
OPENAI_API_KEY=

# --- AWS S3 ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=helm-marine-assets
AWS_REGION=ap-southeast-2

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@helmmarine.co.nz

# --- Firebase ---
FIREBASE_SERVER_KEY=
FIREBASE_PROJECT_ID=

# --- Analytics ---
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# --- Error Tracking ---
SENTRY_DSN=
